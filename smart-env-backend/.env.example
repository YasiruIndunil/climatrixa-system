# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-strong-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── HiveMQ MQTT Broker ─────────────────────────────────────────────────────────
# Get these from: HiveMQ Cloud dashboard after creating a free cluster
MQTT_BROKER_HOST=your-cluster-id.s2.eu.hivemq.cloud
MQTT_BROKER_PORT=8883
MQTT_USERNAME=your-hivemq-username
MQTT_PASSWORD=your-hivemq-password
MQTT_TOPIC_PREFIX=smartenv

# ── App Settings ───────────────────────────────────────────────────────────────
APP_NAME=Smart Environmental Monitoring API
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Runtime ────────────────────────────────────────────────────────────────────
# Python version is set via runtime.txt (for Render) and not read from .env,
# but documented here for local development consistency.
# PYTHON_VERSION=3.12.4
